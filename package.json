{
	"name": "tail",
	"private": true,
	"workspaces": [
		"cvdl-ts",
		"cvdl-editor/fe"
	],
	"scripts": {
		"format": "biome format --write ./cvdl-editor/fe ./cvdl-ts",
		"lint": "npm run --workspace cvdl-editor/fe lint",
		"test:preview-highlight": "node scripts/test-preview-highlight-assumptions.mjs",
		"check:cvdl-ts-push": "node scripts/check-cvdl-ts-version.mjs",
		"setup:hooks": "git config core.hooksPath .githooks"
	},
	"devDependencies": {
		"@biomejs/biome": "1.8.3",
		"playwright": "^1.58.2",
		"typescript": "^6.0.2"
	}
}
